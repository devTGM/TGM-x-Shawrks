{% doc %}
  @prompt
    I want a Hero slideshow which can have 4 - 5 slides which have option for different image for mobile and desktop and has option to put link for particular collection or product , I want this with transparent header
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-slideshow-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    display: block;
    margin-top: {% if block.settings.transparent_header %}-{{ block.settings.header_height }}px{% else %}0{% endif %};
  }

  .ai-hero-slideshow__container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {% if block.settings.transparent_header %}calc({{ block.settings.desktop_height }}px + {{ block.settings.header_height }}px){% else %}{{ block.settings.desktop_height }}px{% endif %};
  }

  .ai-hero-slideshow__slides-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .ai-hero-slideshow__slide-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    transition: opacity {{ block.settings.transition_speed }}s ease-in-out;
    pointer-events: none;
  }

  .ai-hero-slideshow__slide-{{ ai_gen_id }}.active {
    opacity: 1;
    pointer-events: auto;
  }

  .ai-hero-slideshow__slide-link-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    height: 100%;
    position: relative;
  }

  .ai-hero-slideshow__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-hero-slideshow__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-hero-slideshow__image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-hero-slideshow__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-hero-slideshow__mobile-image-{{ ai_gen_id }} {
    display: none;
  }

  .ai-hero-slideshow__controls-{{ ai_gen_id }} {
    position: absolute;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 10px;
    z-index: 10;
  }

  .ai-hero-slideshow__dot-{{ ai_gen_id }} {
    width: {{ block.settings.dot_size }}px;
    height: {{ block.settings.dot_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    opacity: 0.5;
    border: none;
    cursor: pointer;
    transition: opacity 0.3s ease, transform 0.3s ease;
    padding: 0;
  }

  .ai-hero-slideshow__dot-{{ ai_gen_id }}:hover {
    opacity: 0.8;
    transform: scale(1.2);
  }

  .ai-hero-slideshow__dot-{{ ai_gen_id }}.active {
    opacity: 1;
    transform: scale(1.3);
  }

  .ai-hero-slideshow__arrow-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background-color: {{ block.settings.arrow_background }};
    color: {{ block.settings.arrow_color }};
    border: none;
    width: {{ block.settings.arrow_size }}px;
    height: {{ block.settings.arrow_size }}px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
    transition: background-color 0.3s ease, transform 0.3s ease;
    padding: 0;
  }

  .ai-hero-slideshow__arrow-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.arrow_hover_background }};
    transform: translateY(-50%) scale(1.1);
  }

  .ai-hero-slideshow__arrow-{{ ai_gen_id }}--prev {
    left: 20px;
  }

  .ai-hero-slideshow__arrow-{{ ai_gen_id }}--next {
    right: 20px;
  }

  .ai-hero-slideshow__arrow-{{ ai_gen_id }} svg {
    width: calc({{ block.settings.arrow_size }}px * 0.5);
    height: calc({{ block.settings.arrow_size }}px * 0.5);
  }

  @media screen and (max-width: 749px) {
    .ai-hero-slideshow-{{ ai_gen_id }} {
      margin-top: {% if block.settings.transparent_header %}-{{ block.settings.mobile_header_height }}px{% else %}0{% endif %};
    }

    .ai-hero-slideshow__container-{{ ai_gen_id }} {
      height: {% if block.settings.transparent_header %}calc({{ block.settings.mobile_height }}px + {{ block.settings.mobile_header_height }}px){% else %}{{ block.settings.mobile_height }}px{% endif %};
    }

    .ai-hero-slideshow__desktop-image-{{ ai_gen_id }} {
      display: none;
    }

    .ai-hero-slideshow__mobile-image-{{ ai_gen_id }} {
      display: block;
    }

    .ai-hero-slideshow__arrow-{{ ai_gen_id }} {
      width: calc({{ block.settings.arrow_size }}px * 0.8);
      height: calc({{ block.settings.arrow_size }}px * 0.8);
    }

    .ai-hero-slideshow__arrow-{{ ai_gen_id }}--prev {
      left: 10px;
    }

    .ai-hero-slideshow__arrow-{{ ai_gen_id }}--next {
      right: 10px;
    }

    .ai-hero-slideshow__controls-{{ ai_gen_id }} {
      bottom: 20px;
    }

    .ai-hero-slideshow__dot-{{ ai_gen_id }} {
      width: calc({{ block.settings.dot_size }}px * 0.8);
      height: calc({{ block.settings.dot_size }}px * 0.8);
    }
  }
{% endstyle %}

<hero-slideshow-{{ ai_gen_id }}
  class="ai-hero-slideshow-{{ ai_gen_id }}"
  data-autoplay="{{ block.settings.autoplay }}"
  data-autoplay-speed="{{ block.settings.autoplay_speed }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-hero-slideshow__container-{{ ai_gen_id }}">
    <div class="ai-hero-slideshow__slides-{{ ai_gen_id }}">
      {% for i in (1..5) %}
        {% liquid
          assign slide_enabled_key = 'slide_' | append: i | append: '_enabled'
          assign desktop_image_key = 'slide_' | append: i | append: '_desktop_image'
          assign mobile_image_key = 'slide_' | append: i | append: '_mobile_image'
          assign link_type_key = 'slide_' | append: i | append: '_link_type'
          assign collection_key = 'slide_' | append: i | append: '_collection'
          assign product_key = 'slide_' | append: i | append: '_product'

          assign slide_enabled = block.settings[slide_enabled_key]
          assign desktop_image = block.settings[desktop_image_key]
          assign mobile_image = block.settings[mobile_image_key]
          assign link_type = block.settings[link_type_key]
          assign collection = block.settings[collection_key]
          assign product = block.settings[product_key]

          assign slide_url = ''
          if link_type == 'collection' and collection != blank
            assign slide_url = collection.url
          elsif link_type == 'product' and product != blank
            assign slide_url = product.url
          endif
        %}

        {% if slide_enabled %}
          <div
            class="ai-hero-slideshow__slide-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}"
            data-slide-index="{{ forloop.index0 }}"
          >
            {% if slide_url != blank %}
              <a href="{{ slide_url }}" class="ai-hero-slideshow__slide-link-{{ ai_gen_id }}">
            {% else %}
              <div class="ai-hero-slideshow__slide-link-{{ ai_gen_id }}">
            {% endif %}

              {% if desktop_image != blank %}
                <img
                  src="{{ desktop_image | image_url: width: 2000 }}"
                  alt="{{ desktop_image.alt | escape }}"
                  loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                  width="{{ desktop_image.width }}"
                  height="{{ desktop_image.height }}"
                  class="ai-hero-slideshow__image-{{ ai_gen_id }} ai-hero-slideshow__desktop-image-{{ ai_gen_id }}"
                >
              {% else %}
                <div class="ai-hero-slideshow__image-placeholder-{{ ai_gen_id }} ai-hero-slideshow__desktop-image-{{ ai_gen_id }}">
                  {{ 'hero-apparel-1' | placeholder_svg_tag }}
                  {% if forloop.first %}
                    <div class="ai-hero-slideshow__empty-state-{{ ai_gen_id }}">
                      Add a desktop image for slide {{ i }}
                    </div>
                  {% endif %}
                </div>
              {% endif %}

              {% if mobile_image != blank %}
                <img
                  src="{{ mobile_image | image_url: width: 1000 }}"
                  alt="{{ mobile_image.alt | escape }}"
                  loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                  width="{{ mobile_image.width }}"
                  height="{{ mobile_image.height }}"
                  class="ai-hero-slideshow__image-{{ ai_gen_id }} ai-hero-slideshow__mobile-image-{{ ai_gen_id }}"
                >
              {% elsif desktop_image != blank %}
                <img
                  src="{{ desktop_image | image_url: width: 1000 }}"
                  alt="{{ desktop_image.alt | escape }}"
                  loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                  width="{{ desktop_image.width }}"
                  height="{{ desktop_image.height }}"
                  class="ai-hero-slideshow__image-{{ ai_gen_id }} ai-hero-slideshow__mobile-image-{{ ai_gen_id }}"
                >
              {% else %}
                <div class="ai-hero-slideshow__image-placeholder-{{ ai_gen_id }} ai-hero-slideshow__mobile-image-{{ ai_gen_id }}">
                  {{ 'hero-apparel-1' | placeholder_svg_tag }}
                </div>
              {% endif %}

            {% if slide_url != blank %}
              </a>
            {% else %}
              </div>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>

    {% if block.settings.show_arrows %}
      <button
        class="ai-hero-slideshow__arrow-{{ ai_gen_id }} ai-hero-slideshow__arrow-{{ ai_gen_id }}--prev"
        aria-label="Previous slide"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>
      <button
        class="ai-hero-slideshow__arrow-{{ ai_gen_id }} ai-hero-slideshow__arrow-{{ ai_gen_id }}--next"
        aria-label="Next slide"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    {% endif %}

    {% if block.settings.show_dots %}
      <div class="ai-hero-slideshow__controls-{{ ai_gen_id }}">
        {% for i in (1..5) %}
          {% liquid
            assign slide_enabled_key = 'slide_' | append: i | append: '_enabled'
            assign slide_enabled = block.settings[slide_enabled_key]
          %}
          {% if slide_enabled %}
            <button
              class="ai-hero-slideshow__dot-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}"
              data-slide-index="{{ forloop.index0 }}"
              aria-label="Go to slide {{ forloop.index }}"
            ></button>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}
  </div>
</hero-slideshow-{{ ai_gen_id }}>

<script>
  (function() {
    class HeroSlideshow{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 0;
        this.slides = [];
        this.dots = [];
        this.autoplayInterval = null;
      }

      connectedCallback() {
        this.slides = Array.from(this.querySelectorAll('.ai-hero-slideshow__slide-{{ ai_gen_id }}'));
        this.dots = Array.from(this.querySelectorAll('.ai-hero-slideshow__dot-{{ ai_gen_id }}'));
        this.prevButton = this.querySelector('.ai-hero-slideshow__arrow-{{ ai_gen_id }}--prev');
        this.nextButton = this.querySelector('.ai-hero-slideshow__arrow-{{ ai_gen_id }}--next');
        
        this.autoplay = this.dataset.autoplay === 'true';
        this.autoplaySpeed = parseInt(this.dataset.autoplaySpeed) * 1000;

        this.setupEventListeners();
        
        if (this.autoplay && this.slides.length > 1) {
          this.startAutoplay();
        }
      }

      setupEventListeners() {
        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => this.previousSlide());
        }
        
        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => this.nextSlide());
        }

        this.dots.forEach((dot, index) => {
          dot.addEventListener('click', () => this.goToSlide(index));
        });

        this.addEventListener('mouseenter', () => this.stopAutoplay());
        this.addEventListener('mouseleave', () => {
          if (this.autoplay && this.slides.length > 1) {
            this.startAutoplay();
          }
        });
      }

      goToSlide(index) {
        this.slides[this.currentSlide].classList.remove('active');
        if (this.dots[this.currentSlide]) {
          this.dots[this.currentSlide].classList.remove('active');
        }

        this.currentSlide = index;

        this.slides[this.currentSlide].classList.add('active');
        if (this.dots[this.currentSlide]) {
          this.dots[this.currentSlide].classList.add('active');
        }
      }

      nextSlide() {
        const nextIndex = (this.currentSlide + 1) % this.slides.length;
        this.goToSlide(nextIndex);
      }

      previousSlide() {
        const prevIndex = (this.currentSlide - 1 + this.slides.length) % this.slides.length;
        this.goToSlide(prevIndex);
      }

      startAutoplay() {
        this.stopAutoplay();
        this.autoplayInterval = setInterval(() => {
          this.nextSlide();
        }, this.autoplaySpeed);
      }

      stopAutoplay() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
          this.autoplayInterval = null;
        }
      }

      disconnectedCallback() {
        this.stopAutoplay();
      }
    }

    customElements.define('hero-slideshow-{{ ai_gen_id }}', HeroSlideshow{{ ai_gen_id }});
  })();
</script>

